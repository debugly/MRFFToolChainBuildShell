Date: Wed, 28 May 2025 18:49:48 +0800
Subject: fix can't seek to 00:00 bug, baidu neddisk hls
 start_time is less than first_timestamp

---
 libavformat/hls.c | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/libavformat/hls.c b/libavformat/hls.c
index 28c883097a..14fa9da57c 100644
--- a/libavformat/hls.c
+++ b/libavformat/hls.c
@@ -1923,7 +1923,10 @@ static int find_timestamp_in_playlist(HLSContext *c, struct playlist *pls,
 
     if (timestamp < pos) {
         *seq_no = pls->start_seq_no;
-        return 0;
+        if (seg_start_ts) {
+            *seg_start_ts = pos;
+        }
+        return 1;
     }
 
     for (i = 0; i < pls->n_segments; i++) {
